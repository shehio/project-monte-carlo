{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["assets/js/lib/*"]
    }
  },
  "include": ["assets/js/**/*.ts", "tests/**/*.ts"]
}
